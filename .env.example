# ── OpenRouter LLM ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=qwen/qwen3-6b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_PATH=./chroma_data
CHROMA_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── MCP Server ───────────────────────────────────────────────────────────────
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=8000

# ── FastAPI Dashboard ─────────────────────────────────────────────────────────
DASHBOARD_PORT=8080

# ── Google OAuth (Gmail + Calendar) ─────────────────────────────────────────
# Download credentials.json from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_TOKEN_PATH=./token.json

# ── Filesystem Sandbox ───────────────────────────────────────────────────────
FS_ALLOWED_ROOT=./sandbox

# ── Twilio (optional — leave blank to use simulation) ───────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# ── Observer ─────────────────────────────────────────────────────────────────
OBSERVER_POLL_INTERVAL=60
