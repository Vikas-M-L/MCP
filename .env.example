# ── OpenRouter LLM ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-oss-20b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── HuggingFace (optional — higher rate limits for embedding model downloads) ─
HUGGINGFACE_TOKEN=

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_PATH=./chroma_data
CHROMA_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── MCP Server ───────────────────────────────────────────────────────────────
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=8000

# ── FastAPI Dashboard ─────────────────────────────────────────────────────────
DASHBOARD_PORT=8080

# ── Google OAuth (Gmail + Calendar) ─────────────────────────────────────────
# Download credentials.json from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CREDENTIALS_PATH=./secrets/credentials.json
GOOGLE_TOKEN_PATH=./secrets/token.json

# ── Filesystem Sandbox ───────────────────────────────────────────────────────
FS_ALLOWED_ROOT=./sandbox

# ── Twilio (optional — leave blank to use simulation mode) ───────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=
# Public URL for voice approval webhooks (run: ngrok http 8080)
TWILIO_WEBHOOK_BASE_URL=

# ── Observer ─────────────────────────────────────────────────────────────────
OBSERVER_POLL_INTERVAL=60

# ── Meeting auto-schedule ────────────────────────────────────────────────────
# IANA timezone for parsing "April 10 1pm" in emails (match your Google Calendar primary)
MEETING_PARSE_TIMEZONE=UTC
